{
  "expo": {
    "name": "generate-img-mobile",
    "slug": "generate-img-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "generateimgmobile",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.generateimgmobile"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/dm-sans-latin-400-normal.ttf",
            "./assets/fonts/original-surfer-latin-400-normal.ttf"
          ],
          "android": {
            "fonts": [
              {
                "fontFamily": "DMSans-Regular",
                "fontDefinitions": [
                  {
                    "path": "./assets/fonts/dm-sans-latin-400-normal.ttf",
                    "weight": 400
                  }
                ]
              },
              {
                "fontFamily": "OriginalSurfer-Regular",
                "fontDefinitions": [
                  {
                    "path": "./assets/fonts/original-surfer-latin-400-normal.ttf",
                    "weight": 400
                  }
                ]
              }
            ]
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
